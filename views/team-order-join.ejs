<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <section class="page-intro">
      <h1>Commande équipe : <%= teamOrder.team_name %></h1>
      <p>Ajoute ton repas</p>
    </section>

    <section class="checkout-box">
      <form action="/team-order/<%= teamOrder.id %>/add" method="POST">
        <input type="hidden" name="mode" value="sandwich">

        <label>Ton nom</label>
        <input type="text" name="participant_name" required>

        <label>Sandwich</label>
        <select name="product_id" required>
          <% sandwiches.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% }) %>
        </select>

        <label>Crudités</label>
        <select name="crudites_choice" class="crudites-select">
          <option value="avec">Avec crudités</option>
          <option value="sans">Sans crudités</option>
        </select>

        <div class="extras-box crudites-options">
          <p>Crudités gratuites</p>

          <label><input type="checkbox" name="crudites" value="salade" checked> Salade</label>
          <label><input type="checkbox" name="crudites" value="tomate" checked> Tomate</label>
          <label><input type="checkbox" name="crudites" value="carotte" checked> Carotte</label>
        </div>

        <div class="extras-box">
          <p>Suppléments</p>

          <label><input type="checkbox" name="extra_egg"> Œuf +0,50€</label>
          <label><input type="checkbox" name="extra_cheese"> Fromage +0,50€</label>
        </div>

        <button type="submit" class="btn btn-primary">Ajouter</button>
      </form>
    </section>
  </main>

  <script>
    const select = document.querySelector('.crudites-select');
    const box = document.querySelector('.crudites-options');

    function update() {
      const inputs = box.querySelectorAll('input');

      if (select.value === 'sans') {
        box.classList.add('extras-disabled');
        inputs.forEach(i => {
          i.checked = false;
          i.disabled = true;
        });
      } else {
        box.classList.remove('extras-disabled');
        inputs.forEach(i => {
          i.disabled = false;
          i.checked = true;
        });
      }
    }

    select.addEventListener('change', update);
    update();
  </script>

  <%- include('partials/footer') %>
</body>
</html>