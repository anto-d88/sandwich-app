<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container menu-page">
    <section class="page-intro">
      <span class="section-badge">Petit-déjeuner entreprise</span>
      <h1>Petits-déjeuners d’équipe livrés en entreprise</h1>
      <p>
        Commandez facilement un petit-déjeuner pour vos réunions, formations,
        accueils de nouveaux collaborateurs ou équipes du matin.
      </p>

      <p style="margin-top:10px; color:#15803d; font-weight:800;">
        Livraison disponible sur créneaux : 8h, 9h, 10h et 11h.
      </p>
    </section>

    <section style="
      margin-top:20px;
      padding:20px;
      border-radius:18px;
      background:#fff7ed;
      border:1px solid #fed7aa;
    ">
      <h2 style="margin-bottom:8px;">⏰ À savoir avant de commander</h2>
      <p style="font-size:16px; line-height:1.6;">
        Les petits-déjeuners doivent être commandés au plus tard
        <strong>la veille avant 16h</strong>.
      </p>
      <p style="margin-top:8px; color:#9a3412;">
        Exemple : pour une livraison mardi matin, la commande doit être validée
        lundi avant 16h.
      </p>
    </section>

    <section class="menu-top-banner" style="margin-top:22px;">
      <div>
        <strong>Fonctionnement simple</strong>
        <p>1. Choisissez une date • 2. Choisissez un créneau • 3. Sélectionnez une formule</p>
      </div>

      <div>
        <a href="/menu" class="btn btn-secondary">Retour au menu</a>
      </div>
    </section>

    <section class="checkout-box" style="margin-top: 24px;">
      <h2>1. Date et créneau de livraison</h2>

      <p style="margin-bottom:16px; color:#6b7280;">
        Le calendrier bloque automatiquement les dates trop proches lorsque la limite
        de commande est dépassée.
      </p>

      <div class="checkout-form">
        <label>
          Date de livraison
          <input type="date" id="breakfastDeliveryDate" required>
        </label>

        <label>
          Créneau de livraison
          <select id="breakfastDeliveryTime" required>
            <option value="08:00">08h00</option>
            <option value="09:00">09h00</option>
            <option value="10:00">10h00</option>
            <option value="11:00">11h00</option>
          </select>
        </label>

        <div id="breakfastDeliveryInfo" style="
          margin-top:16px;
          padding:14px;
          background:#f0fdf4;
          border:1px solid #bbf7d0;
          border-radius:12px;
          color:#15803d;
          font-weight:800;
        "></div>
      </div>
    </section>

    <section class="page-intro" style="margin-top: 38px;">
      <h2>2. Formules suggérées</h2>
      <p>
        Des formules prêtes à commander pour gagner du temps.
      </p>
    </section>

    <section class="products-grid">
      <% const fixedFormulas = breakfastFormulas.filter(product => {
        const name = String(product.name || '').toLowerCase();
        return !name.includes('personnalisée') && !name.includes('personnalisee');
      }); %>

      <% if (!fixedFormulas.length) { %>
        <div class="empty-box">
          <p>Aucune formule petit-déjeuner disponible pour le moment.</p>
        </div>
      <% } else { %>
        <% fixedFormulas.forEach(product => { %>
          <article class="product-card product-card--pro">
            <div class="product-image-wrap">
              <img
                src="<%= product.image_url || '/images/default-product.jpg' %>"
                alt="<%= product.name %>"
                class="product-image"
              >
            </div>

            <div class="product-card__content">
              <span class="product-category">formule entreprise</span>
              <h2><%= product.name %></h2>

              <p class="product-description">
                <%= product.description || 'Formule petit-déjeuner pour entreprise.' %>
              </p>

              <% if (product.stock_quantity <= 0) { %>
                <span class="product-badge product-badge--danger">Rupture</span>
                <p class="stock-warning stock-warning--danger">❌ Indisponible</p>
                <button class="btn btn-danger" disabled>Indisponible</button>
              <% } else { %>
                <p class="stock-ok">✔ Disponible</p>

                <div class="product-bottom">
                  <p class="product-price">
                    <%= Number(product.price).toFixed(2).replace('.', ',') %> €
                  </p>

                  <form action="/cart/add" method="POST" class="product-form-inline breakfast-formula-form">
                    <input type="hidden" name="id" value="<%= product.id %>">
                    <input type="hidden" name="breakfast_delivery_date" class="breakfast-delivery-date-input">
                    <input type="hidden" name="breakfast_delivery_time" class="breakfast-delivery-time-input">

                    <input
                      type="number"
                      name="quantity"
                      value="1"
                      min="1"
                      max="<%= product.stock_quantity %>"
                      class="qty-input"
                    >

                    <button type="submit" class="btn btn-primary">
                      Ajouter
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          </article>
        <% }) %>
      <% } %>
    </section>

    <section class="page-intro" style="margin-top: 46px;">
      <h2>3. Composer une formule personnalisée</h2>
      <p>
        Pour 5, 10, 20 personnes ou plus. Vous choisissez exactement les quantités.
      </p>
    </section>

    <section class="checkout-box" style="margin-top: 18px;">
      <div style="
        margin-bottom:18px;
        padding:14px;
        border-radius:12px;
        background:#f8fafc;
        border:1px solid #e5e7eb;
      ">
        <strong>Formule personnalisée</strong>
        <p style="margin-top:6px; color:#6b7280;">
          Idéal si vous avez une équipe avec des besoins différents : plus de cafés,
          plus de jus d’orange, moins de viennoiseries, etc.
        </p>
      </div>

      <form action="/cart/add-breakfast-custom" method="POST" class="checkout-form breakfast-custom-form">
        <input type="hidden" name="delivery_date" class="breakfast-delivery-date-input">
        <input type="hidden" name="delivery_time" class="breakfast-delivery-time-input">

        <label>
          Nombre de personnes
          <input type="number" name="people_count" value="10" min="5" required>
        </label>

        <label>
          Croissants
          <input type="number" name="croissants" value="5" min="0" required>
        </label>

        <label>
          Pains au chocolat
          <input type="number" name="pains_chocolat" value="5" min="0" required>
        </label>

        <label>
          Cafés
          <input type="number" name="cafes" value="10" min="0" required>
        </label>

        <label>
          Thés
          <input type="number" name="thes" value="0" min="0" required>
        </label>

        <label>
          Jus d’orange
          <input type="number" name="jus_orange" value="0" min="0" required>
        </label>

        <button type="submit" class="btn btn-primary">
          Ajouter la formule personnalisée
        </button>
      </form>

      <p style="margin-top:16px; color:#6b7280;">
        Prix calculé automatiquement : croissant 1,20€, pain au chocolat 1,30€,
        café 1,50€, thé 1,50€, jus d’orange 2,00€.
      </p>
    </section>
  </main>

  <script>
    function pad(value) {
      return String(value).padStart(2, '0');
    }

    function toDateInputValue(date) {
      return [
        date.getFullYear(),
        pad(date.getMonth() + 1),
        pad(date.getDate())
      ].join('-');
    }

    function formatFrenchDate(dateValue) {
      if (!dateValue) return '';

      const [year, month, day] = dateValue.split('-').map(Number);
      const date = new Date(year, month - 1, day);

      return date.toLocaleDateString('fr-FR', {
        weekday: 'long',
        day: '2-digit',
        month: 'long',
        year: 'numeric'
      });
    }

    function getMinimumBreakfastDate() {
      const now = new Date();
      const minimumDate = new Date(now);

      minimumDate.setDate(minimumDate.getDate() + 1);

      const isAfterCutoff =
        now.getHours() > 16 ||
        (now.getHours() === 16 && now.getMinutes() >= 0);

      if (isAfterCutoff) {
        minimumDate.setDate(minimumDate.getDate() + 1);
      }

      return minimumDate;
    }

    const dateInput = document.getElementById('breakfastDeliveryDate');
    const timeInput = document.getElementById('breakfastDeliveryTime');
    const infoBox = document.getElementById('breakfastDeliveryInfo');
    const hiddenDateInputs = document.querySelectorAll('.breakfast-delivery-date-input');
    const hiddenTimeInputs = document.querySelectorAll('.breakfast-delivery-time-input');

    function syncBreakfastDelivery() {
      const selectedDate = dateInput.value;
      const selectedTime = timeInput.value;

      hiddenDateInputs.forEach(input => {
        input.value = selectedDate;
      });

      hiddenTimeInputs.forEach(input => {
        input.value = selectedTime;
      });

      if (selectedDate && selectedTime) {
        const timeLabel = selectedTime.replace(':00', 'h');
        infoBox.textContent =
          `Livraison prévue le ${formatFrenchDate(selectedDate)} à ${timeLabel}.`;
      }
    }

    const minimumDate = getMinimumBreakfastDate();
    const minimumValue = toDateInputValue(minimumDate);

    dateInput.min = minimumValue;
    dateInput.value = minimumValue;

    syncBreakfastDelivery();

    dateInput.addEventListener('change', syncBreakfastDelivery);
    timeInput.addEventListener('change', syncBreakfastDelivery);

    document.querySelectorAll('.breakfast-formula-form, .breakfast-custom-form').forEach(form => {
      form.addEventListener('submit', (event) => {
        syncBreakfastDelivery();

        if (!dateInput.value || !timeInput.value) {
          event.preventDefault();
          alert('Merci de choisir une date et un créneau de livraison.');
        }
      });
    });
  </script>

  <%- include('partials/footer') %>
</body>
</html>