<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <section class="page-intro">
      <h1><%= teamOrder.team_name %></h1>
    </section>

    <section class="checkout-box">
      <input type="text" id="participant_name" placeholder="Ton prénom" required>
    </section>

    <div class="products-grid">
      <% sandwiches.forEach(product => { %>
        <article class="product-card product-card--pro">

          <div class="product-image-wrap">
            <img src="<%= product.image_url %>" class="product-image">
          </div>

          <div class="product-card__content">
            <h2><%= product.name %></h2>

            <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-form">

              <input type="hidden" name="product_id" value="<%= product.id %>">
              <input type="hidden" name="participant_name" class="hidden-name">
              <input type="hidden" name="mode" value="sandwich">

              <input type="number" name="quantity" value="1" min="1">

              <% if (product.name.toLowerCase().includes('jambon')) { %>
                <select name="sauce_choice">
                  <option value="beurre">Beurre</option>
                  <option value="mayonnaise">Mayonnaise</option>
                </select>
              <% } %>

              <select name="crudites_choice" class="crudites-select">
                <option value="avec">Avec crudités</option>
                <option value="sans">Sans crudités</option>
              </select>

              <div class="crudites-options">
                <label><input type="checkbox" name="crudites" value="salade"> salade +0,50€</label>
                <label><input type="checkbox" name="crudites" value="tomate"> tomate +0,50€</label>
                <label><input type="checkbox" name="crudites" value="carotte"> carotte +0,50€</label>
                <label><input type="checkbox" name="crudites" value="oeuf"> oeuf +0,50€</label>
              </div>

              <label>
                <input type="checkbox" name="extra_cheese">
                fromage +0,50€
              </label>

              <button>Ajouter</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>

    <script>
      document.querySelectorAll('.team-form').forEach(form => {
        const select = form.querySelector('.crudites-select');
        const options = form.querySelector('.crudites-options');

        function update() {
          if (select.value === 'sans') {
            options.style.opacity = '0.4';
            options.querySelectorAll('input').forEach(i => {
              i.checked = false;
              i.disabled = true;
            });
          } else {
            options.style.opacity = '1';
            options.querySelectorAll('input').forEach(i => {
              i.disabled = false;
            });
          }
        }

        select.addEventListener('change', update);
        update();
      });

      const nameInput = document.getElementById('participant_name');
      document.querySelectorAll('.hidden-name').forEach(input => {
        nameInput.addEventListener('input', () => {
          input.value = nameInput.value;
        });
      });
    </script>

  </main>

  <%- include('partials/footer') %>
</body>
</html>