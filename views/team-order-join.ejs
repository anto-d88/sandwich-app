<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <section class="page-intro">
      <span class="section-badge">Commande d’équipe</span>
      <h1><%= teamOrder.team_name %></h1>
      <p>Créneau : <strong><%= teamOrder.delivery_slot %></strong></p>
      <p>Adresse : <strong><%= teamOrder.delivery_address %></strong></p>

      <div class="hero__actions">
        <a href="/team-order/<%= teamOrder.id %>/summary" class="btn btn-secondary">
          Voir le résumé équipe
        </a>

        <a href="/team-order/<%= teamOrder.id %>/formule" class="btn btn-primary">
          Composer une formule
        </a>
      </div>
    </section>

    <section class="menu-top-banner">
      <div>
        <strong>Formule complète</strong>
        <p>Sandwich + boisson + dessert à 7,50€ — économie de 1€</p>
      </div>
      <div>
        <a href="/team-order/<%= teamOrder.id %>/formule" class="btn btn-primary">
          Créer une formule
        </a>
      </div>
    </section>

    <section class="checkout-box" style="margin-bottom: 24px;">
      <h2>Votre nom</h2>
      <input type="text" id="participant_name" placeholder="Votre prénom / nom" required>
      <p style="margin-top: 10px; color: #6b7280;">
        Entrez votre nom avant d’ajouter un produit à la commande d’équipe.
      </p>
    </section>

    <section class="page-intro">
      <h2>🥪 Sandwichs seuls</h2>
      <p>Ajoutez uniquement un sandwich à la commande d’équipe.</p>
    </section>

    <div class="products-grid">
      <% sandwiches.forEach(product => { %>
        <article class="product-card product-card--pro">
          <div class="product-image-wrap">
            <img
              src="<%= product.image_url || '/images/default-product.jpg' %>"
              alt="<%= product.name %>"
              class="product-image"
            >
          </div>

          <div class="product-card__content">
            <span class="product-category">sandwich</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || '' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <span class="product-badge product-badge--danger">Rupture</span>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else if (product.stock_quantity <= 3) { %>
              <span class="product-badge">🔥 Très demandé</span>
              <p class="stock-warning stock-warning--danger">⚠️ Plus que quelques sandwichs disponibles</p>
            <% } else if (product.stock_quantity <= 6) { %>
              <p class="stock-warning">⏳ Stock limité aujourd’hui</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <div class="product-bottom">
              <p class="product-price">4,50 €</p>

              <% if (product.stock_quantity <= 0) { %>
                <button class="btn btn-danger" disabled>Rupture</button>
              <% } else { %>
                <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-inline-form">
                  <input type="hidden" name="mode" value="sandwich">
                  <input type="hidden" name="participant_name" class="participant-name-hidden">
                  <input type="hidden" name="product_id" value="<%= product.id %>">

                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="<%= product.stock_quantity %>"
                    class="qty-input"
                  >

                  <button type="submit" class="btn btn-primary">
                    Ajouter
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🥤 Boissons seules</h2>
      <p>Ajoutez uniquement une boisson à la commande d’équipe.</p>
    </section>

    <div class="products-grid products-grid--small">
      <% boissons.forEach(product => { %>
        <article class="product-card">
          <div class="product-card__content">
            <span class="product-category">boisson</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || 'Boisson fraîche' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else if (product.stock_quantity <= 3) { %>
              <p class="stock-warning stock-warning--danger">⚠️ Stock faible</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <div class="product-bottom">
              <p class="product-price">1,50 €</p>

              <% if (product.stock_quantity <= 0) { %>
                <button class="btn btn-danger" disabled>Rupture</button>
              <% } else { %>
                <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-inline-form">
                  <input type="hidden" name="mode" value="boisson">
                  <input type="hidden" name="participant_name" class="participant-name-hidden">
                  <input type="hidden" name="product_id" value="<%= product.id %>">

                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="<%= product.stock_quantity %>"
                    class="qty-input"
                  >

                  <button type="submit" class="btn btn-primary">
                    Ajouter
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🍰 Desserts seuls</h2>
      <p>Ajoutez uniquement un dessert à la commande d’équipe.</p>
    </section>

    <div class="products-grid products-grid--small">
      <% desserts.forEach(product => { %>
        <article class="product-card">
          <div class="product-card__content">
            <span class="product-category">dessert</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || 'Dessert du jour' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else if (product.stock_quantity <= 3) { %>
              <p class="stock-warning stock-warning--danger">⚠️ Stock faible</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <div class="product-bottom">
              <p class="product-price">2,50 €</p>

              <% if (product.stock_quantity <= 0) { %>
                <button class="btn btn-danger" disabled>Rupture</button>
              <% } else { %>
                <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-inline-form">
                  <input type="hidden" name="mode" value="dessert">
                  <input type="hidden" name="participant_name" class="participant-name-hidden">
                  <input type="hidden" name="product_id" value="<%= product.id %>">

                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="<%= product.stock_quantity %>"
                    class="qty-input"
                  >

                  <button type="submit" class="btn btn-primary">
                    Ajouter
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>

    <section class="checkout-box" style="margin-top: 34px;">
      <h2>Participants déjà ajoutés</h2>

      <% if (!items.length) { %>
        <p>Aucune commande ajoutée pour le moment.</p>
      <% } else { %>
        <% let total = 0; %>

        <% items.forEach(item => { %>
          <% const lineTotal = Number(item.unit_price) * Number(item.quantity); %>
          <% total += lineTotal; %>

          <div class="checkout-item">
            <div>
              <strong><%= item.participant_name %></strong><br>
              <span><%= item.product_name %> x <%= item.quantity %></span>
            </div>
            <div>
              <%= lineTotal.toFixed(2).replace('.', ',') %> €
            </div>
          </div>
        <% }) %>

        <hr>
        <p class="checkout-total">
          <strong>Total actuel : <%= total.toFixed(2).replace('.', ',') %> €</strong>
        </p>

        <div style="margin-top: 20px;">
          <a href="/team-order/<%= teamOrder.id %>/summary" class="btn btn-primary">
            Voir le total et payer
          </a>
        </div>
      <% } %>
    </section>
  </main>

  <script>
    const participantInput = document.getElementById('participant_name');
    const hiddenParticipantInputs = document.querySelectorAll('.participant-name-hidden');

    function syncParticipantName() {
      const value = participantInput.value.trim();

      hiddenParticipantInputs.forEach(input => {
        input.value = value;
      });
    }

    participantInput.addEventListener('input', syncParticipantName);

    document.querySelectorAll('.team-inline-form').forEach(form => {
      form.addEventListener('submit', function (event) {
        syncParticipantName();

        if (!participantInput.value.trim()) {
          event.preventDefault();
          alert('Merci d’indiquer votre prénom ou votre nom avant d’ajouter un produit.');
        }
      });
    });
  </script>

  <%- include('partials/footer') %>
</body>
</html>