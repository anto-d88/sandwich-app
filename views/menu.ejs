<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="menu-page container">
    <section class="page-intro">
      <span class="section-badge">Commande rapide</span>
      <h1>Notre carte</h1>
      <p>Sandwichs froids, boissons et desserts pour une pause simple, rapide et livrée sur créneau fixe.</p>
    </section>

    <section class="menu-top-banner">
      <div>
        <strong>Formule complète</strong>
        <p>Sandwich + boisson + dessert à 7,50€ — vous économisez 1€</p>
      </div>
      <div>
        <a href="/formule" class="btn btn-primary">Composer ma formule</a>
      </div>
    </section>

    <section class="page-intro" style="margin-top: 10px;">
      <h2>🥪 Sandwichs</h2>
      <p>Crudités gratuites au choix : salade, tomate, carotte. Œuf et fromage en supplément.</p>
    </section>

    <section class="products-grid">
      <% products.filter(product => product.category === 'sandwich').forEach(product => { %>
        <article class="product-card product-card--pro">
          <a href="/product/<%= product.id %>" class="product-image-wrap">
            <img src="<%= product.image_url || '/images/default-product.jpg' %>" alt="<%= product.name %>" class="product-image">
          </a>

          <div class="product-card__content">
            <span class="product-category">sandwich</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || '' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <span class="product-badge product-badge--danger">Rupture</span>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

            <% if (product.stock_quantity <= 0) { %>
              <button class="btn btn-danger" disabled>Rupture de stock</button>
            <% } else { %>
              <form action="/cart/add" method="POST" class="product-form">
                <input type="hidden" name="id" value="<%= product.id %>">

                <label>
                  Quantité
                  <input type="number" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>" class="qty-input">
                </label>

                <% if ((product.name || '').toLowerCase().includes('jambon')) { %>
                  <label>
                    Base
                    <select name="sauce_choice" required>
                      <option value="beurre">Beurre</option>
                      <option value="mayonnaise">Mayonnaise</option>
                    </select>
                  </label>
                <% } %>

                <label>
                  Crudités
                  <select name="crudites_choice" class="crudites-select">
                    <option value="avec">Avec crudités</option>
                    <option value="sans">Sans crudités</option>
                  </select>
                </label>

                <div class="extras-box crudites-options">
                  <p>Crudités gratuites au choix</p>

                  <label class="extra-pill">
                    <input type="checkbox" name="crudites" value="salade" checked>
                    <span>Salade</span>
                  </label>

                  <label class="extra-pill">
                    <input type="checkbox" name="crudites" value="tomate" checked>
                    <span>Tomate</span>
                  </label>

                  <label class="extra-pill">
                    <input type="checkbox" name="crudites" value="carotte" checked>
                    <span>Carotte</span>
                  </label>
                </div>

                <div class="extras-box paid-options-box">
                  <p>Suppléments</p>

                  <label class="extra-pill">
                    <input type="checkbox" name="extra_egg">
                    <span>Œuf +0,50€</span>
                  </label>

                  <label class="extra-pill cheese-pill">
                    <input type="checkbox" name="extra_cheese">
                    <span>Tranche de fromage +0,50€</span>
                  </label>
                </div>

                <button type="submit" class="btn btn-primary">Ajouter</button>
              </form>
            <% } %>

            <a href="/product/<%= product.id %>" class="product-link">Voir le détail</a>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🥤 Boissons</h2>
      <p>Des boissons simples à ajouter à votre commande.</p>
    </section>

    <section class="products-grid products-grid--small">
      <% products.filter(product => product.category === 'boisson').forEach(product => { %>
        <article class="product-card product-card--pro">
          <div class="product-image-wrap">
            <img src="<%= product.image_url || '/images/default-product.jpg' %>" alt="<%= product.name %>" class="product-image">
          </div>

          <div class="product-card__content">
            <span class="product-category">boisson</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || 'Boisson fraîche' %></p>
            <p class="stock-ok">✔ Disponible</p>

            <div class="product-bottom">
              <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

              <form action="/cart/add" method="POST" class="product-form-inline">
                <input type="hidden" name="id" value="<%= product.id %>">
                <input type="number" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>" class="qty-input">
                <button type="submit" class="btn btn-primary">Ajouter</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🍰 Desserts</h2>
      <p>Pour compléter votre pause déjeuner.</p>
    </section>

    <section class="products-grid products-grid--small">
      <% products.filter(product => product.category === 'dessert').forEach(product => { %>
        <article class="product-card product-card--pro">
          <div class="product-image-wrap">
            <img src="<%= product.image_url || '/images/default-product.jpg' %>" alt="<%= product.name %>" class="product-image">
          </div>

          <div class="product-card__content">
            <span class="product-category">dessert</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || 'Dessert du jour' %></p>
            <p class="stock-ok">✔ Disponible</p>

            <div class="product-bottom">
              <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

              <form action="/cart/add" method="POST" class="product-form-inline">
                <input type="hidden" name="id" value="<%= product.id %>">
                <input type="number" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>" class="qty-input">
                <button type="submit" class="btn btn-primary">Ajouter</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  </main>

  <script>
    document.querySelectorAll('.product-form').forEach(form => {
      const select = form.querySelector('.crudites-select');
      const options = form.querySelector('.crudites-options');

      if (!select || !options) return;

      function updateCrudites() {
        const inputs = options.querySelectorAll('input');

        if (select.value === 'sans') {
          options.classList.add('extras-disabled');
          inputs.forEach(input => {
            input.checked = false;
            input.disabled = true;
          });
        } else {
          options.classList.remove('extras-disabled');
          inputs.forEach(input => {
            input.disabled = false;
            if (!input.checked) input.checked = true;
          });
        }
      }

      select.addEventListener('change', updateCrudites);
      updateCrudites();
    });
  </script>

  <%- include('partials/footer') %>
</body>
</html>