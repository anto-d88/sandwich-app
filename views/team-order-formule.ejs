<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <section class="page-intro">
      <span class="section-badge">Formule équipe</span>
      <h1>Composer une formule</h1>
      <p>Commande : <strong><%= teamOrder.team_name %></strong></p>
      <p>1 sandwich + 1 boisson + 1 dessert pour <strong>7,50€</strong>.</p>
    </section>

    <form action="/team-order/<%= teamOrder.id %>/formule/add" method="POST" class="formula-layout">
      <section class="checkout-box">
        <h2>Votre nom</h2>
        <input type="text" name="participant_name" placeholder="Votre prénom / nom" required>
      </section>

      <section class="formula-column">
        <h2>🥪 Sandwich</h2>
        <div class="products-grid products-grid--small">
          <% sandwiches.forEach(product => { %>
            <label class="formula-card">
              <input type="radio" name="sandwich_id" value="<%= product.id %>" required>
              <div class="formula-card__body">
                <img src="<%= product.image_url || '/images/default-product.jpg' %>" class="formula-card__image">
                <div class="formula-card__content">
                  <span class="product-category">sandwich</span>
                  <h3><%= product.name %></h3>
                  <strong>4,50 €</strong>
                </div>
              </div>
            </label>
          <% }) %>
        </div>
      </section>

      <section class="formula-column">
        <h2>🥤 Boisson</h2>
        <div class="products-grid products-grid--small">
          <% boissons.forEach(product => { %>
            <label class="formula-card">
              <input type="radio" name="boisson_id" value="<%= product.id %>" required>
              <div class="formula-card__body">
                <div class="formula-card__content">
                  <span class="product-category">boisson</span>
                  <h3><%= product.name %></h3>
                  <strong>1,50 €</strong>
                </div>
              </div>
            </label>
          <% }) %>
        </div>

        <h2 style="margin-top:24px;">🍰 Dessert</h2>
        <div class="products-grid products-grid--small">
          <% desserts.forEach(product => { %>
            <label class="formula-card">
              <input type="radio" name="dessert_id" value="<%= product.id %>" required>
              <div class="formula-card__body">
                <div class="formula-card__content">
                  <span class="product-category">dessert</span>
                  <h3><%= product.name %></h3>
                  <strong>2,50 €</strong>
                </div>
              </div>
            </label>
          <% }) %>
        </div>
      </section>

      <aside class="formula-summary">
        <div class="checkout-box">
          <h2>Résumé</h2>
          <p>Total séparé : <strong>8,50 €</strong></p>
          <p>Prix formule : <strong>7,50 €</strong></p>
          <p style="color:#15803d;font-weight:700;">Économie : 1,00 €</p>

          <button type="submit" class="btn btn-primary">Ajouter à l’équipe</button>
        </div>
      </aside>
    </form>
  </main>

  <%- include('partials/footer') %>
</body>
</html>