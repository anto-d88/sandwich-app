<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <section class="page-intro">
      <span class="section-badge">Commande d’équipe</span>
      <h1><%= teamOrder.team_name %></h1>
      <p>Créneau : <strong><%= teamOrder.delivery_slot %></strong></p>
      <p>Adresse : <strong><%= teamOrder.delivery_address %></strong></p>
      <p>
        <a href="/team-order/<%= teamOrder.id %>/summary" class="btn btn-secondary">Voir le résumé équipe</a>
      </p>
    </section>

    <section class="menu-top-banner">
      <div>
        <strong>Choisissez votre mode</strong>
        <p>Sandwich seul ou formule complète</p>
      </div>
    </section>

    <section class="checkout-box" style="margin-bottom: 24px;">
      <h2>Votre nom</h2>
      <input type="text" id="participant_name" placeholder="Votre prénom / nom" required>
    </section>

    <section class="page-intro">
      <h2>🥪 Ajouter un sandwich seul</h2>
    </section>

    <div class="products-grid">
      <% sandwiches.forEach(product => { %>
        <article class="product-card product-card--pro">
          <div class="product-image-wrap">
            <img
              src="<%= product.image_url || '/images/default-product.jpg' %>"
              alt="<%= product.name %>"
              class="product-image"
            >
          </div>

          <div class="product-card__content">
            <span class="product-category">sandwich</span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || '' %></p>
            <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

            <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-inline-form">
              <input type="hidden" name="mode" value="sandwich">
              <input type="hidden" name="participant_name" class="participant-name-hidden">
              <input type="hidden" name="product_id" value="<%= product.id %>">
              <input type="number" name="quantity" value="1" min="1" class="qty-input">
              <button type="submit" class="btn btn-primary">Ajouter à l’équipe</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>

    <section class="page-intro" style="margin-top: 34px;">
  <h2>🥤 Ajouter une boisson seule</h2>
</section>

<div class="products-grid products-grid--small">
  <% boissons.forEach(product => { %>
    <article class="product-card">
      <div class="product-card__content">
        <span class="product-category">boisson</span>
        <h2><%= product.name %></h2>
        <p class="product-description"><%= product.description || 'Boisson fraîche' %></p>
        <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

        <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-inline-form">
          <input type="hidden" name="mode" value="boisson">
          <input type="hidden" name="participant_name" class="participant-name-hidden">
          <input type="hidden" name="product_id" value="<%= product.id %>">
          <input type="number" name="quantity" value="1" min="1" class="qty-input">
          <button type="submit" class="btn btn-primary">Ajouter à l’équipe</button>
        </form>
      </div>
    </article>
  <% }) %>
</div>

<section class="page-intro" style="margin-top: 34px;">
  <h2>🍰 Ajouter un dessert seul</h2>
</section>

<div class="products-grid products-grid--small">
  <% desserts.forEach(product => { %>
    <article class="product-card">
      <div class="product-card__content">
        <span class="product-category">dessert</span>
        <h2><%= product.name %></h2>
        <p class="product-description"><%= product.description || 'Dessert du jour' %></p>
        <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

        <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="team-inline-form">
          <input type="hidden" name="mode" value="dessert">
          <input type="hidden" name="participant_name" class="participant-name-hidden">
          <input type="hidden" name="product_id" value="<%= product.id %>">
          <input type="number" name="quantity" value="1" min="1" class="qty-input">
          <button type="submit" class="btn btn-primary">Ajouter à l’équipe</button>
        </form>
      </div>
    </article>
  <% }) %>
</div>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🍽 Composer une formule</h2>
      <p>Choisissez un sandwich, une boisson et un dessert.</p>
    </section>

    <form action="/team-order/<%= teamOrder.id %>/add" method="POST" class="formula-layout">
      <input type="hidden" name="mode" value="formule">
      <input type="hidden" name="participant_name" id="participant_name_formula">

      <section class="formula-column">
        <div class="page-intro">
          <h3>🥪 Sandwich</h3>
        </div>

        <div class="products-grid products-grid--small">
          <% sandwiches.forEach(product => { %>
            <label class="formula-card">
              <input type="radio" name="sandwich_id" value="<%= product.id %>" data-price="<%= Number(product.price) %>" required>
              <div class="formula-card__body">
                <img
                  src="<%= product.image_url || '/images/default-product.jpg' %>"
                  alt="<%= product.name %>"
                  class="formula-card__image"
                >
                <div class="formula-card__content">
                  <span class="product-category">sandwich</span>
                  <h3><%= product.name %></h3>
                  <p><%= product.description || '' %></p>
                  <strong><%= Number(product.price).toFixed(2).replace('.', ',') %> €</strong>
                </div>
              </div>
            </label>
          <% }) %>
        </div>
      </section>

      <section class="formula-column">
        <div class="page-intro">
          <h3>🥤 Boisson</h3>
        </div>

        <div class="products-grid products-grid--small">
          <% boissons.forEach(product => { %>
            <label class="formula-card">
              <input type="radio" name="boisson_id" value="<%= product.id %>" data-price="<%= Number(product.price) %>" required>
              <div class="formula-card__body">
                <div class="formula-card__content">
                  <span class="product-category">boisson</span>
                  <h3><%= product.name %></h3>
                  <p><%= product.description || 'Boisson fraîche' %></p>
                  <strong><%= Number(product.price).toFixed(2).replace('.', ',') %> €</strong>
                </div>
              </div>
            </label>
          <% }) %>
        </div>

        <div class="page-intro" style="margin-top: 24px;">
          <h3>🍰 Dessert</h3>
        </div>

        <div class="products-grid products-grid--small">
          <% desserts.forEach(product => { %>
            <label class="formula-card">
              <input type="radio" name="dessert_id" value="<%= product.id %>" data-price="<%= Number(product.price) %>" required>
              <div class="formula-card__body">
                <div class="formula-card__content">
                  <span class="product-category">dessert</span>
                  <h3><%= product.name %></h3>
                  <p><%= product.description || 'Dessert du jour' %></p>
                  <strong><%= Number(product.price).toFixed(2).replace('.', ',') %> €</strong>
                </div>
              </div>
            </label>
          <% }) %>
        </div>
      </section>

      <aside class="formula-summary">
        <div class="checkout-box">
          <h2>Résumé de la formule</h2>
          <p><strong>Total séparé :</strong> <span id="total-separe">0,00 €</span></p>
          <p><strong>Prix formule :</strong> <span id="prix-formule">0,00 €</span></p>
          <p style="color:#15803d; font-weight:700;">
            <strong>Économie :</strong> <span id="economie">0,20 €</span>
          </p>

          <button type="submit" class="btn btn-primary" style="margin-top:16px;">
            Ajouter la formule à l’équipe
          </button>
        </div>
      </aside>
    </form>

    <section class="checkout-box" style="margin-top: 28px;">
      <h2>Participants déjà ajoutés</h2>

      <% if (!items.length) { %>
        <p>Aucune commande ajoutée pour le moment.</p>
      <% } else { %>
        <% items.forEach(item => { %>
          <div class="checkout-item">
            <div>
              <strong><%= item.participant_name %></strong><br>
              <span><%= item.product_name %> x <%= item.quantity %></span>
            </div>
            <div>
              <%= (Number(item.unit_price) * Number(item.quantity)).toFixed(2).replace('.', ',') %> €
            </div>
          </div>
        <% }) %>
      <% } %>
    </section>
  </main>

  <script>
    const participantInput = document.getElementById('participant_name');
    const hiddenParticipantInputs = document.querySelectorAll('.participant-name-hidden');
    const participantFormulaInput = document.getElementById('participant_name_formula');

    function syncParticipantName() {
      const value = participantInput.value;
      hiddenParticipantInputs.forEach(input => input.value = value);
      participantFormulaInput.value = value;
    }

    participantInput.addEventListener('input', syncParticipantName);
    syncParticipantName();

    const sandwichInputs = document.querySelectorAll('input[name="sandwich_id"]');
    const boissonInputs = document.querySelectorAll('input[name="boisson_id"]');
    const dessertInputs = document.querySelectorAll('input[name="dessert_id"]');

    const totalSepareEl = document.getElementById('total-separe');
    const prixFormuleEl = document.getElementById('prix-formule');
    const economieEl = document.getElementById('economie');

    function getCheckedPrice(inputs) {
      const checked = Array.from(inputs).find(input => input.checked);
      return checked ? Number(checked.dataset.price) : 0;
    }

    function formatEuro(value) {
      return value.toFixed(2).replace('.', ',') + ' €';
    }

    function updateFormulePrice() {
      const total =
        getCheckedPrice(sandwichInputs) +
        getCheckedPrice(boissonInputs) +
        getCheckedPrice(dessertInputs);

      const formule = total > 0 ? Math.max(0, total - 0.20) : 0;
      const economie = total > 0 ? total - formule : 0;

      totalSepareEl.textContent = formatEuro(total);
      prixFormuleEl.textContent = formatEuro(formule);
      economieEl.textContent = formatEuro(economie);
    }

    [...sandwichInputs, ...boissonInputs, ...dessertInputs].forEach(input => {
      input.addEventListener('change', updateFormulePrice);
    });

    updateFormulePrice();
  </script>
</body>
</html>