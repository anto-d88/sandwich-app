<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <section class="page-intro">
      <span class="section-badge">Commande d’équipe</span>
      <h1>Créer une commande d’équipe</h1>
      <p>
        Créez un lien de commande pour votre équipe. Chacun ajoute son sandwich,
        sa boisson, son dessert ou sa formule.
      </p>
      <p>
        Créneaux proposés : <strong>11h, 13h et 15h</strong>.
        Quand un créneau du jour est fermé, il est automatiquement proposé pour demain.
      </p>
    </section>

    <% if (error) { %>
      <section class="team-error-box">
        <h2>Créneau indisponible</h2>
        <p><%= error %></p>
        <p>Choisissez un autre créneau disponible ci-dessous.</p>
      </section>
    <% } %>

    <section class="checkout-layout">
      <div class="checkout-box">
        <h2>Informations de livraison</h2>

        <form action="/team-order/create" method="POST" class="checkout-form">
          <input
            type="text"
            name="team_name"
            placeholder="Nom de l’équipe / entreprise"
            value="<%= old.team_name || '' %>"
            required
          >

          <input
            type="text"
            name="contact_name"
            placeholder="Nom du responsable"
            value="<%= old.contact_name || '' %>"
            required
          >

          <input
            type="text"
            name="contact_phone"
            placeholder="Téléphone"
            value="<%= old.contact_phone || '' %>"
            required
          >

          <input
            type="text"
            name="delivery_address"
            placeholder="Adresse de livraison"
            value="<%= old.delivery_address || '' %>"
            required
          >

          <label>
            Créneau de livraison
            <select name="delivery_slot" required>
              <option value="">Choisir un créneau</option>

              <% slots.forEach(slot => { %>
                <option
                  value="<%= slot.value %>"
                  <%= old.delivery_slot === slot.value ? 'selected' : '' %>
                  <%= slot.isUnavailable ? 'disabled' : '' %>
                >
                  <%= slot.label %>
                  <% if (slot.isFull) { %>
                    — Complet
                  <% } else { %>
                    — Commande ouverte pour demain
                  <% } %>
                </option>
              <% }) %>
            </select>
          </label>

          <button type="submit" class="btn btn-primary">
            Créer la commande équipe
          </button>
        </form>
      </div>

      <aside class="checkout-box">
        <h2>Créneaux disponibles</h2>

        <div class="slot-list">
          <% slots.forEach(slot => { %>
            <div class="slot-item <%= slot.isUnavailable ? 'slot-item--full' : '' %>">
              <div>
                <strong><%= slot.label %></strong>

                <p>
                  <% if (slot.isFull) { %>
                    Complet
                  <% } else { %>
                   <%= slot.max - slot.count %> Commande ouverte pour demain
                  <% } %>
                </p>
              </div>

              <% if (slot.isFull) { %>
                <span class="status-badge status-nouvelle">Complet</span>
              <% } else if (slot.isTomorrow) { %>
                <span class="status-badge status-en-preparation">Prévoir demain</span>
              <% } else { %>
                <span class="status-badge status-payee">Disponible</span>
              <% } %>
            </div>
          <% }) %>
        </div>

        <p style="margin-top:16px; color:#6b7280;">
          Exemple : si le créneau de 11h est fermé aujourd’hui, il devient automatiquement disponible pour demain 11h.
        </p>
      </aside>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>