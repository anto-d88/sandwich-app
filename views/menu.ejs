<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="menu-page container">
    <section class="page-intro">
      <span class="section-badge">Commande rapide</span>
      <h1>Notre carte</h1>
      <p>
        Sandwichs, boissons et desserts pour une pause déjeuner simple, rapide et livrée sur créneau fixe.
      </p>
    </section>

    <section class="menu-top-banner">
      <div>
        <strong>Menu complet</strong>
        <p>Sandwich + Boisson + Dessert</p>
      </div>
      <div>
        <strong>8,90€</strong>
      </div>
    </section>

    <section class="page-intro" style="margin-top: 10px;">
      <h2>🥪 Sandwichs</h2>
      <p>Nos sandwichs baguette froids préparés pour les équipes.</p>
    </section>

    <section class="products-grid">
      <% products.filter(product => product.category === 'sandwich').forEach(product => { %>
        <article class="product-card product-card--pro">
          <a href="/product/<%= product.id %>" class="product-image-wrap">
            <img
              src="<%= product.image_url || '/images/default-product.jpg' %>"
              alt="<%= product.name %>"
              class="product-image"
            >
          </a>

          <div class="product-card__content">
            <span class="product-category"><%= product.category || 'sandwich' %></span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || '' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <span class="product-badge">Rupture</span>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else if (product.stock_quantity <= 3) { %>
              <span class="product-badge">🔥 Très demandé</span>
              <p class="stock-warning stock-warning--danger">⚠️ Plus que quelques sandwichs disponibles</p>
            <% } else if (product.stock_quantity <= 6) { %>
              <p class="stock-warning">⏳ Stock limité aujourd’hui</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <div class="product-bottom">
              <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

              <% if (product.stock_quantity <= 0) { %>
                <button class="btn btn-danger" disabled>Rupture de stock</button>
              <% } else { %>
                <form action="/cart/add" method="POST" class="product-form-inline">
                  <input type="hidden" name="id" value="<%= product.id %>">
                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="<%= product.stock_quantity %>"
                    class="qty-input"
                  >
                  <button type="submit" class="btn btn-primary">Ajouter</button>
                </form>
              <% } %>
            </div>

            <a href="/product/<%= product.id %>" class="product-link">Voir le détail</a>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🥤 Boissons</h2>
      <p>Des boissons simples à ajouter à votre sandwich.</p>
    </section>

    <section class="products-grid products-grid--small">
      <% products.filter(product => product.category === 'boisson').forEach(product => { %>
        <article class="product-card">
          <div class="product-card__content">
            <span class="product-category"><%= product.category || 'boisson' %></span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || 'Boisson fraîche' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else if (product.stock_quantity <= 3) { %>
              <p class="stock-warning stock-warning--danger">⚠️ Stock faible</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <div class="product-bottom">
              <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

              <% if (product.stock_quantity <= 0) { %>
                <button class="btn btn-danger" disabled>Rupture</button>
              <% } else { %>
                <form action="/cart/add" method="POST" class="product-form-inline">
                  <input type="hidden" name="id" value="<%= product.id %>">
                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="<%= product.stock_quantity %>"
                    class="qty-input"
                  >
                  <button type="submit" class="btn btn-primary">Ajouter</button>
                </form>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="page-intro" style="margin-top: 34px;">
      <h2>🍰 Desserts</h2>
      <p>Pour compléter votre pause déjeuner.</p>
    </section>

    <section class="products-grid products-grid--small">
      <% products.filter(product => product.category === 'dessert').forEach(product => { %>
        <article class="product-card">
          <div class="product-card__content">
            <span class="product-category"><%= product.category || 'dessert' %></span>
            <h2><%= product.name %></h2>
            <p class="product-description"><%= product.description || 'Dessert du jour' %></p>

            <% if (product.stock_quantity <= 0) { %>
              <p class="stock-warning stock-warning--danger">❌ Rupture de stock</p>
            <% } else if (product.stock_quantity <= 3) { %>
              <p class="stock-warning stock-warning--danger">⚠️ Stock faible</p>
            <% } else { %>
              <p class="stock-ok">✔ Disponible</p>
            <% } %>

            <div class="product-bottom">
              <p class="product-price"><%= Number(product.price).toFixed(2).replace('.', ',') %> €</p>

              <% if (product.stock_quantity <= 0) { %>
                <button class="btn btn-danger" disabled>Rupture</button>
              <% } else { %>
                <form action="/cart/add" method="POST" class="product-form-inline">
                  <input type="hidden" name="id" value="<%= product.id %>">
                  <input
                    type="number"
                    name="quantity"
                    value="1"
                    min="1"
                    max="<%= product.stock_quantity %>"
                    class="qty-input"
                  >
                  <button type="submit" class="btn btn-primary">Ajouter</button>
                </form>
              <% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>